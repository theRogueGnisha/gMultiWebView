<UserControl x:Class="gMultiWebView.BrowserPanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border Background="#1e1e1e" BorderBrush="#333" BorderThickness="1" CornerRadius="2">
    <Border x:Name="BrowserHost" Background="#1a1a1a" Focusable="True"
            MouseLeftButtonDown="BrowserHost_MouseLeftButtonDown"
            PreviewMouseWheel="BrowserHost_PreviewMouseWheel"/>
  </Border>
</UserControl>
