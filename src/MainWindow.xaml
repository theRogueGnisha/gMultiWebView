<Window x:Class="gMultiWebView.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="gMultiWebView"
        Height="720" Width="1280"
        MinHeight="400" MinWidth="640"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackground}"
        KeyDown="Window_KeyDown">
    <Grid x:Name="RootGrid">
        <!-- Content layer: 6-panel or 2x2 -->
        <Grid x:Name="MainGrid" Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="Row0" Height="*"/>
                <RowDefinition x:Name="Row1" Height="*"/>
                <RowDefinition x:Name="Row2" Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <ContentControl x:Name="Slot1" Grid.Row="0" Grid.Column="0" Margin="2"/>
            <ContentControl x:Name="Slot2" Grid.Row="0" Grid.Column="1" Margin="2"/>
            <ContentControl x:Name="Slot3" Grid.Row="0" Grid.Column="2" Margin="2"/>
            <ContentControl x:Name="Slot4" Grid.Row="1" Grid.Column="0" Margin="2"/>
            <ContentControl x:Name="Slot5" Grid.Row="2" Grid.Column="0" Margin="2"/>
            <ContentControl x:Name="SlotFocus" Grid.Row="1" Grid.Column="1" Grid.RowSpan="2" Grid.ColumnSpan="2" Margin="2"/>
        </Grid>
        <Grid x:Name="Grid2x2" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <ContentControl x:Name="Slot2x2_0" Grid.Row="0" Grid.Column="0" Margin="2"/>
            <ContentControl x:Name="Slot2x2_1" Grid.Row="0" Grid.Column="1" Margin="2"/>
            <ContentControl x:Name="Slot2x2_2" Grid.Row="1" Grid.Column="0" Margin="2"/>
            <ContentControl x:Name="Slot2x2_3" Grid.Row="1" Grid.Column="1" Margin="2"/>
        </Grid>
    </Grid>
</Window>
