<Application x:Class="gMultiWebView.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:gMultiWebView"
             Startup="Application_Startup">
    <Application.Resources>
        <ResourceDictionary>
            <SolidColorBrush x:Key="WindowBackground" Color="#1a1a1a"/>
            <SolidColorBrush x:Key="PanelBackground" Color="#1e1e1e"/>
            <SolidColorBrush x:Key="TitleBarBackground" Color="#252526"/>
            <SolidColorBrush x:Key="TextForeground" Color="#e0e0e0"/>
            <SolidColorBrush x:Key="MutedForeground" Color="#888888"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
