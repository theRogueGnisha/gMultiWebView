<Window x:Class="gMultiWebView.UrlControlWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="gMultiWebView - Controller"
        Height="525" Width="1055"
        MinHeight="280" MinWidth="380"
        WindowStartupLocation="Manual"
        Background="#1e1e1e"
        ResizeMode="CanResizeWithGrip">
  <Window.Resources>
    <Style TargetType="TextBox">
      <Setter Property="Background" Value="#3c3c3c"/>
      <Setter Property="Foreground" Value="#e0e0e0"/>
      <Setter Property="BorderBrush" Value="#555"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="6,4"/>
      <Setter Property="FontSize" Value="12"/>
    </Style>
    <Style TargetType="Button">
      <Setter Property="Background" Value="#0e639c"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="8,4"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
  </Window.Resources>
  <Grid Margin="10" VerticalAlignment="Top">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>
    <Border x:Name="LayoutSection" Grid.Row="0" Margin="0,0,0,10" VerticalAlignment="Top" HorizontalAlignment="Center" MinWidth="220" MaxWidth="320"/>
    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                  VerticalAlignment="Top" VerticalContentAlignment="Top">
      <Grid x:Name="SlotsGrid" VerticalAlignment="Top"/>
    </ScrollViewer>
  </Grid>
</Window>
